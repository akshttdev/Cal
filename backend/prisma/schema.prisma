// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Switched to standard prisma-client-js for broad compatibility
// (Prisma v7 with prisma-client provider has adapter complexity we avoid here)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User ───────────────────────────────────────────────────────────────────
// Single default user (no auth). Owns event types and availability.
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())

  eventTypes   EventType[]
  availability Availability[]

  @@map("users")
}

// ─── EventType ───────────────────────────────────────────────────────────────
// Represents a bookable meeting type (e.g. "30-min call").
// 'slug' is the public URL key: /book/[slug]
model EventType {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String   @default("")
  duration    Int      // duration in minutes
  slug        String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("event_types")
}

// ─── Availability ─────────────────────────────────────────────────────────────
// One row per active day of the week for a user.
// dayOfWeek: 0 = Sunday, 1 = Monday, …, 6 = Saturday
// startTime / endTime stored as "HH:MM" 24h strings (e.g. "09:00", "17:00")
model Availability {
  id        String  @id @default(uuid())
  userId    String
  dayOfWeek Int     // 0-6
  startTime String  // "HH:MM" 24h
  endTime   String  // "HH:MM" 24h
  isActive  Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek])
  @@map("availability")
}

// ─── Booking ──────────────────────────────────────────────────────────────────
// A concrete booking made by a guest for a specific event type.
// startTime / endTime are stored in UTC.
// Double-booking prevention: check overlaps before insert in a transaction.
model Booking {
  id          String        @id @default(uuid())
  eventTypeId String
  guestName   String
  guestEmail  String
  startTime   DateTime      // UTC
  endTime     DateTime      // UTC
  status      BookingStatus @default(CONFIRMED)
  createdAt   DateTime      @default(now())

  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}